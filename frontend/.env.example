# OpenStats Frontend — Variables d'environnement
# ─────────────────────────────────────────────────
# Copiez ce fichier en `.env` et remplissez les valeurs.

# ── API ──────────────────────────────────────────
# URL de l'API backend. Laisser vide si le frontend est servi par Flask
# (même domaine) ou si le proxy Vite est utilisé (dev local).
VITE_API_URL=

# ── Auth ─────────────────────────────────────────
# Active le mode authentification (doit correspondre à AUTH_ENABLED côté backend).
# En mode open-source local, laisser false.
VITE_AUTH_ENABLED=false

# ── Supabase (optionnel, seulement si AUTH_ENABLED=true) ─
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
