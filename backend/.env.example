# OpenStats — Variables d'environnement
# ─────────────────────────────────────────────────
# Copiez ce fichier en `.env` et remplissez les valeurs.

# ── Sécurité ──────────────────────────────────────
# En LOCAL_DEV_MODE=true, une clé aléatoire est générée automatiquement.
# En production, cette variable est OBLIGATOIRE.
SECRET_KEY=change-me-in-production
AUTH_ENABLED=false
LOCAL_DEV_MODE=false
# En mode open-source local, laissez AUTH_ENABLED=false.
# Pour réactiver un futur mode SaaS/multi-utilisateur : AUTH_ENABLED=true.

# ── Auth (optionnel, seulement si AUTH_ENABLED=true) ─────
# JWT access/refresh basés sur SECRET_KEY.
# Si AUTH_ENABLED=true et LOCAL_DEV_MODE=true,
# un admin par défaut est créé : admin@labs.elmas.fr
LOCAL_DEV_ADMIN_PASSWORD=admin123

# ── CORS (origines autorisées, séparées par des virgules) ─
CORS_ORIGINS=http://localhost:5173
# En production : CORS_ORIGINS=https://votre-domaine.example

# ── Upload / Stockage ────────────────────────────
# Dossiers créés automatiquement au démarrage.
UPLOAD_FOLDER=uploads
DATA_DIR=data
REPORTS_DIR=reports
# Taille max d'upload en Mo (défaut: 200 en local, 50 en production)
MAX_UPLOAD_MB=200
# Chemin vers le build frontend pour servir le SPA en production
FRONTEND_DIST_DIR=../frontend/dist

# ── IA / LLM ─────────────────────────────────────
# Anthropic (Claude) — utilisé pour les insights et la génération de code
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
# DeepSeek — alternative économique (optionnel)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Base de données ───────────────────────────────
# Par défaut : SQLite locale dans `backend/data/openstats.db`
# Optionnel : PostgreSQL local ou distant
# Pour Render/Supabase : postgresql://user:password@host:5432/dbname
# DATABASE_URL=postgresql://user:password@localhost:5432/openstats

# ── Celery / Redis (jobs asynchrones) ────────────
# Sans Redis, les jobs s'exécutent en mode synchrone.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Rate limiting (désactivé par défaut en mode local)
RATELIMIT_STORAGE_URI=memory://

# ── Flask ────────────────────────────────────────
FLASK_DEBUG=false
# Ne JAMAIS mettre FLASK_ENV=production avec LOCAL_DEV_MODE=true
# FLASK_ENV=production

# ── Logging ──────────────────────────────────────
# Niveaux : DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
