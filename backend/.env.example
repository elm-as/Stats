# OpenStats — Variables d'environnement
# ─────────────────────────────────────────────────
# Copiez ce fichier en `.env` et remplissez les valeurs.

# ── Sécurité ──────────────────────────────────────
SECRET_KEY=change-me-in-production
LOCAL_DEV_MODE=true
# En production, mettre LOCAL_DEV_MODE=false et FLASK_ENV=production

# ── Supabase Auth (OBLIGATOIRE en production) ─────
SUPABASE_JWT_SECRET=
# Trouvable dans : Supabase Dashboard > Settings > API > JWT Secret

# ── CORS (origines autorisées, séparées par des virgules) ─
CORS_ORIGINS=http://localhost:5173
# En production : CORS_ORIGINS=https://votre-domaine.netlify.app

# ── Upload / Stockage ────────────────────────────
UPLOAD_FOLDER=uploads
DATA_DIR=data
REPORTS_DIR=reports
MAX_UPLOAD_MB=50
FRONTEND_DIST_DIR=../frontend/dist

# ── IA / LLM ─────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Base de données (Supabase PostgreSQL) ──────────
# Pour la production, utilisez l'URL de connexion Pooler de Supabase :
# 1. Allez dans Supabase Dashboard > Project Settings > Database
# 2. Copiez l'URI "Transaction pooler"
# 3. Remplacez "postgres://" par "postgresql://" et indiquez votre mot de passe.
# DATABASE_URL=postgresql://postgres.[votre-ref]:[votre-mot-de-passe]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Celery / Redis ───────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Flask ────────────────────────────────────────
FLASK_DEBUG=false
# FLASK_ENV=production
